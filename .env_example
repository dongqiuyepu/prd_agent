DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# browser-use event bus timeouts (seconds) — override defaults for slow apps
# NavigateToUrlEvent default is 30s — must exceed PAGE_LATENCY_MS
TIMEOUT_NavigateToUrlEvent=60
# BrowserStateRequestEvent: agent reads page DOM after load; give it extra time
TIMEOUT_BrowserStateRequestEvent=60

# Agent page-load wait (seconds) — must exceed PAGE_LATENCY_MS/1000
AGENT_MIN_PAGE_LOAD_S=6.0
AGENT_NETWORK_IDLE_S=3.0

# App latency (ms) — set to 0 to disable for fast CI runs
# PAGE_LATENCY_MS=5000
# LATENCY_MS=800
